.venv/
__pycache__/
*.pyc
*.egg-info/
build/
dist/

# JS deps (live in a named volume; never committed). package-lock.json
# IS committed for reproducible installs.
node_modules/

# Captured run logs (command output, not source). Regenerated on every run.
tools/logs/

# Repo-root scratch for ad-hoc command output (show-tree dumps, log
# tails, etc.). Re-readable by the Read tool; delete files when done.
/tmp/

# Playwright run artifacts (traces, screenshots, HTML report). Also
# listed in [clean].targets. Regenerated on every test run.
test-results/
playwright-report/

# Claude Code per-session runtime state (recreated on launch).
.claude/scheduled_tasks.lock
